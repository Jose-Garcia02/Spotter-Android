<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background_dark">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Rendimiento de Rutina"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:layout_gravity="center_horizontal"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona una rutina de tu historial"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"/>
    <Spinner
        android:id="@+id/spinnerPerformanceExercises"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_input_rounded"
        android:layout_marginBottom="16dp"
        android:padding="4dp"/>
    <TextView
        android:id="@+id/tvComparisonHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No hay sesiones previas para comparar"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPerformanceSets"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
